RewriteEngine On
RewriteBase /front/

# Laisser passer les fichiers/dossiers réels
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Accueil / liste actualités
RewriteRule ^$ index.php?page=actu_generale [L,QSA]
RewriteRule ^actualites/?$ index.php?page=actu_generale [L,QSA]

# Catégorie
RewriteRule ^categorie/([a-z0-9-]+)/?$ index.php?page=actu_generale&categorie=$1 [L,QSA,NC]

# Détail article
RewriteRule ^article/([a-z0-9-]+)/?$ index.php?page=article&slug=$1 [L,QSA,NC]

# Caching for performance
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json
</IfModule>
